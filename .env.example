# Port the API listens on
PORT=5000

# development | production
NODE_ENV=development

# Comma-separated list of allowed CORS origins, e.g. https://quantumlogics.dev,https://app.quantumlogics.dev
# Leave empty to allow all origins (fine for local dev, not recommended in production).
ALLOWED_ORIGINS=

# Absolute path to the qrun executable. If unset, the server searches a few
# default locations relative to the backend (see resolveQrunPath in server.js).
QRUN_PATH=

# Max time (ms) a single execution is allowed to run before being killed.
EXEC_TIMEOUT_MS=10000

# Max accepted length (characters) of submitted source code.
MAX_CODE_LENGTH=20000

# Rate limiting for /api/execute
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# API key for the chatbot (Groq API key)
GROQ_API_KEY=
